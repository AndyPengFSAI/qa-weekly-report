# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Your Atlassian account email address
ATLASSIAN_EMAIL=your@email.com

# Atlassian API token — generate one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
# Note: for the Atlassian remote MCP (mcp.atlassian.com) an OAuth 2.0 token
# is required instead of an API token. The REST API fallback uses this value
# for Basic Auth, which accepts standard API tokens.
ATLASSIAN_API_TOKEN=your_api_token_here

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Zephyr Scale API key — generate at: Jira → Apps → Zephyr Scale → API Access Tokens
# Only needed for boards with zephyr_project_key set (currently: Xander/HEAL)
ZEPHYR_SCALE_API_KEY=your_zephyr_scale_api_key_here
